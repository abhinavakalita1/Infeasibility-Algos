<?xml version="1.0"?>
<robot name="five_dof_arm">

  <!-- ========================================================= -->
  <!-- MATERIALS -->
  <!-- ========================================================= -->

  <material name="gray">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <!-- ========================================================= -->
  <!-- BASE LINK -->
  <!-- ========================================================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.10" length="0.10"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.10" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="5.0"/>

      <inertia
        ixx="0.02"
        ixy="0.0"
        ixz="0.0"
        iyy="0.02"
        iyz="0.0"
        izz="0.01"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- LINK 1 -->
  <!-- ========================================================= -->

  <link name="link1">

    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.025"
        ixy="0.0"
        ixz="0.0"
        iyy="0.025"
        iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- LINK 2 -->
  <!-- ========================================================= -->

  <link name="link2">

    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.025"
        ixy="0.0"
        ixz="0.0"
        iyy="0.025"
        iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- LINK 3 -->
  <!-- ========================================================= -->

  <link name="link3">

    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.025"
        ixy="0.0"
        ixz="0.0"
        iyy="0.025"
        iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- LINK 4 -->
  <!-- ========================================================= -->

  <link name="link4">

    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.025"
        ixy="0.0"
        ixz="0.0"
        iyy="0.025"
        iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- LINK 5 -->
  <!-- ========================================================= -->

  <link name="link5">

    <visual>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.40"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.40"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <mass value="0.8"/>

      <inertia
        ixx="0.015"
        ixy="0.0"
        ixz="0.0"
        iyy="0.015"
        iyz="0.0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- ========================================================= -->
  <!-- JOINT 1 : BASE YAW -->
  <!-- ========================================================= -->

  <joint name="joint1" type="revolute">

    <parent link="base_link"/>
    <child link="link1"/>

    <origin xyz="0 0 0.10" rpy="0 0 0"/>

    <!-- rotation about z -->
    <axis xyz="0 0 1"/>

    <limit
      lower="-3.14"
      upper="3.14"
      effort="20"
      velocity="2"/>

  </joint>

  <!-- ========================================================= -->
  <!-- JOINT 2 -->
  <!-- ========================================================= -->

  <joint name="joint2" type="revolute">

    <parent link="link1"/>
    <child link="link2"/>

    <origin xyz="0 0 0.50" rpy="0 0 0"/>

    <!-- elbow style -->
    <axis xyz="0 1 0"/>

    <limit
      lower="-1.57"
      upper="1.57"
      effort="15"
      velocity="2"/>

  </joint>

  <!-- ========================================================= -->
  <!-- JOINT 3 -->
  <!-- ========================================================= -->

  <joint name="joint3" type="revolute">

    <parent link="link2"/>
    <child link="link3"/>

    <origin xyz="0 0 0.50" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit
      lower="-1.57"
      upper="1.57"
      effort="15"
      velocity="2"/>

  </joint>

  <!-- ========================================================= -->
  <!-- JOINT 4 -->
  <!-- ========================================================= -->

  <joint name="joint4" type="revolute">

    <parent link="link3"/>
    <child link="link4"/>

    <origin xyz="0 0 0.50" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit
      lower="-1.57"
      upper="1.57"
      effort="10"
      velocity="2"/>

  </joint>

  <!-- ========================================================= -->
  <!-- JOINT 5 -->
  <!-- ========================================================= -->

  <joint name="joint5" type="revolute">

    <parent link="link4"/>
    <child link="link5"/>

    <origin xyz="0 0 0.50" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit
      lower="-1.57"
      upper="1.57"
      effort="10"
      velocity="2"/>

  </joint>

</robot>